{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "index.ts!",
    "src/decorators/index.ts!",
    "src/rules/index.ts!",
    "src/symbols.ts!",
    "src/transformers/index.ts!",
    "bench/*.bench.ts",
    "bench/class-validator/*.cv.bench.ts",
    "scripts/*.ts"
  ],
  "project": ["src/**/*.ts", "bench/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"],
  "ignoreBinaries": ["tsc"],
  "ignoreDependencies": ["@commitlint/types"],
  "ignoreExportsUsedInFile": true
}
