{
  "name": "@zipbul/baker",
  "version": "0.0.1",
  "description": "Decorator-based validate + transform with inline code generation. class-validator DX, AOT-level performance, zero reflect-metadata.",
  "license": "MIT",
  "author": "Junhyung Park (https://github.com/parkrevil)",
  "repository": {
    "type": "git",
    "url": "https://github.com/zipbul/baker.git"
  },
  "bugs": "https://github.com/zipbul/baker/issues",
  "homepage": "https://github.com/zipbul/baker#readme",
  "keywords": [
    "validation",
    "transform",
    "decorator",
    "dto",
    "class-validator",
    "class-transformer",
    "serialize",
    "deserialize",
    "code-generation",
    "bun",
    "zipbul"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./decorators": {
      "import": "./dist/src/decorators/index.js",
      "types": "./dist/src/decorators/index.d.ts"
    },
    "./aot": {
      "import": "./dist/src/aot/index.js",
      "types": "./dist/src/aot/index.d.ts"
    },
    "./rules": {
      "import": "./dist/src/rules/index.js",
      "types": "./dist/src/rules/index.d.ts"
    },
    "./symbols": {
      "import": "./dist/src/symbols.js",
      "types": "./dist/src/symbols.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@zipbul/result": "^0.0.3"
  },
  "scripts": {
    "build": "bun build index.ts src/decorators/index.ts src/aot/index.ts src/rules/index.ts src/symbols.ts --outdir dist --target bun --format esm --splitting --packages external --sourcemap=linked --root . && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7"
  }
}
