{
  "name": "@zipbul/baker",
  "version": "2.0.0",
  "description": "Decorator-based validate + transform with inline code generation. class-validator DX, AOT-level performance, zero reflect-metadata.",
  "license": "MIT",
  "author": "Junhyung Park (https://github.com/parkrevil)",
  "repository": {
    "type": "git",
    "url": "https://github.com/zipbul/baker.git"
  },
  "bugs": "https://github.com/zipbul/baker/issues",
  "homepage": "https://github.com/zipbul/baker#readme",
  "keywords": [
    "validation",
    "transform",
    "decorator",
    "dto",
    "typescript",
    "runtime-validation",
    "type-safe",
    "class-validator",
    "class-transformer",
    "serialize",
    "deserialize",
    "code-generation",
    "bun",
    "zipbul"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./decorators": {
      "import": "./dist/src/decorators/index.js",
      "types": "./dist/src/decorators/index.d.ts"
    },
    "./rules": {
      "import": "./dist/src/rules/index.js",
      "types": "./dist/src/rules/index.d.ts"
    },
    "./symbols": {
      "import": "./dist/src/symbols.js",
      "types": "./dist/src/symbols.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@zipbul/result": "1.0.0"
  },
  "scripts": {
    "build": "bun build index.ts src/decorators/index.ts src/rules/index.ts src/symbols.ts --outdir dist --target bun --format esm --splitting --packages external --sourcemap=linked --root . --production && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:memory": "bun run scripts/check-memory.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@sinclair/typebox": "^0.34.48",
    "@types/bun": "^1.3.9",
    "ajv": "^8.18.0",
    "arktype": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "husky": "^9.1.7",
    "mitata": "^1.0.34",
    "reflect-metadata": "^0.2.2",
    "valibot": "^1.3.1",
    "zod": "^4.3.6"
  }
}