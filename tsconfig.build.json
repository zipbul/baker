{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "noEmitOnError": true,
    "emitDeclarationOnly": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "allowImportingTsExtensions": false
  },
  "include": ["index.ts", "src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "test", "bench"]
}
